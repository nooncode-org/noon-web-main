# Core runtime
DATABASE_URL=
POSTGRES_URL=
DB_CONNECT_TIMEOUT_SECONDS=20
DB_IDLE_TIMEOUT_SECONDS=30
DB_MAX_CONNECTIONS=10
AUTH_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MAXWELL_PUBLIC_BASE_URL=http://localhost:3000

# OAuth / auth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Maxwell generation
OPENAI_API_KEY=
V0_API_KEY=

# Internal review access
REVIEW_ALLOWED_EMAILS=
REVIEW_API_SECRET=

# Proposal email delivery
MAIL_PROVIDER=
MAIL_FROM=
MAIL_REPLY_TO=
RESEND_API_KEY=

# Scheduled jobs / observability
CRON_SECRET=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Stripe hosted Checkout (Phase 2 / deferred after manual payment evidence soft launch)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Noon App bridge (signed outbound webhooks). After a client requests the formal proposal, the website
# POSTs the draft to NOON_APP_BASE_URL + /api/integrations/website/inbound-proposal with HMAC headers.
# NOON_WEBSITE_WEBHOOK_SECRET is the canonical name per the cross-repo contract v1 and must match
# the value configured in Noon App for this website integration.
# If either NOON_APP_BASE_URL or the secret is empty, the draft is still stored in proposal_request
# but the webhook is skipped.
NOON_APP_BASE_URL=
NOON_WEBSITE_WEBHOOK_SECRET=
# Legacy name kept during the migration window. The runtime accepts either name; prefer
# NOON_WEBSITE_WEBHOOK_SECRET going forward and remove this row once ops has renamed the
# variable in every environment.
NOON_APP_WEBHOOK_SECRET=

# Vercel system variables are injected by Vercel in deployed environments.
# Keep local values empty unless you are intentionally reproducing a deploy context.
# VERCEL=
# VERCEL_ENV=
# VERCEL_URL=
