# Core runtime
DATABASE_URL=
POSTGRES_URL=
DB_CONNECT_TIMEOUT_SECONDS=20
DB_IDLE_TIMEOUT_SECONDS=30
DB_MAX_CONNECTIONS=10
AUTH_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MAXWELL_PUBLIC_BASE_URL=http://localhost:3000

# OAuth / auth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Maxwell generation
OPENAI_API_KEY=
V0_API_KEY=
# Optional override for the default OpenAI chat model used by lib/api-ia.ts
# and lib/maxwell/brief-extractor.ts. When empty/unset, the code defaults to
# `gpt-5.5` (GA since 2026-04-23). Set this to `gpt-4.1` to roll back to the
# previous model without redeploying — useful for rate-limit or cost-spike
# response. A fixed snapshot like `gpt-5.5-2026-04-23` pins behaviour.
OPENAI_DEFAULT_MODEL=

# Internal review access
REVIEW_ALLOWED_EMAILS=
REVIEW_API_SECRET=

# Proposal email delivery
MAIL_PROVIDER=
MAIL_FROM=
MAIL_REPLY_TO=
RESEND_API_KEY=
# B8 #2/#3 lifecycle emails (payment received + workspace ready). OFF by
# default — set to "1" only after the Resend domain has been verified in
# production and a smoke test confirms delivery. When unset/empty the new
# senders in lib/maxwell/lifecycle-emails.ts return a `skipped` sentinel
# instead of calling Resend, so merging the feature is safe long before
# the Resend handshake. Flipping this flag does NOT need a redeploy.
MAXWELL_LIFECYCLE_EMAILS=

# Scheduled jobs / observability
CRON_SECRET=
# SENTRY_DSN is the activation gate (B42). When empty/blank, the Sentry SDK
# never initialises and `log.error` / `log.warn` calls from
# lib/server/logger.ts are NOT forwarded — Vercel logs remain the sole sink.
# When set, instrumentation.ts initialises @sentry/nextjs at boot and
# registers a log hook. Get the DSN from the Sentry project settings.
SENTRY_DSN=
# Float in [0, 1]. Fraction of transactions sent to Sentry for performance
# tracing. Defaults to 0.1 (10%) inside the code when this env var is unset
# or invalid. Pick 0 to disable tracing while still capturing errors.
SENTRY_TRACES_SAMPLE_RATE=0.05

# Stripe hosted Checkout (Phase 2 / deferred after manual payment evidence soft launch)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Noon App bridge (signed outbound webhooks). After a client requests the formal proposal, the website
# POSTs the draft to NOON_APP_BASE_URL + /api/integrations/website/inbound-proposal with HMAC headers.
# NOON_WEBSITE_WEBHOOK_SECRET is the canonical name per the cross-repo contract v1 and must match
# the value configured in Noon App for this website integration.
# If either NOON_APP_BASE_URL or the secret is empty, the draft is still stored in proposal_request
# but the webhook is skipped.
NOON_APP_BASE_URL=
NOON_WEBSITE_WEBHOOK_SECRET=
# Legacy name kept during the migration window. The runtime accepts either name; prefer
# NOON_WEBSITE_WEBHOOK_SECRET going forward and remove this row once ops has renamed the
# variable in every environment.
NOON_APP_WEBHOOK_SECRET=

# Vercel system variables are injected by Vercel in deployed environments.
# Keep local values empty unless you are intentionally reproducing a deploy context.
# VERCEL=
# VERCEL_ENV=
# VERCEL_URL=
