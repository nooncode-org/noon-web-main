# Core runtime
DATABASE_URL=
DB_CONNECT_TIMEOUT_SECONDS=20
DB_IDLE_TIMEOUT_SECONDS=30
DB_MAX_CONNECTIONS=10
AUTH_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MAXWELL_PUBLIC_BASE_URL=http://localhost:3000

# OAuth / auth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Maxwell generation
OPENAI_API_KEY=
V0_API_KEY=

# Internal review access
REVIEW_ALLOWED_EMAILS=
REVIEW_API_SECRET=

# Proposal email delivery
MAIL_PROVIDER=
MAIL_FROM=
MAIL_REPLY_TO=
RESEND_API_KEY=

# Stripe hosted Checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Noon App bridge (signed outbound webhooks). After a client requests the formal proposal, the website
# POSTs the draft to NOON_APP_BASE_URL + /api/integrations/website/inbound-proposal with HMAC headers.
# NOON_APP_WEBHOOK_SECRET must match the value configured in Noon App for this website integration.
# If either variable is empty, the draft is still stored in proposal_request but the webhook is skipped.
NOON_APP_BASE_URL=
NOON_APP_WEBHOOK_SECRET=
